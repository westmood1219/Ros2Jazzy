<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ════════════════════════════
       全局尺寸常量（所有数字只写一次）
  ════════════════════════════════ -->

  <!-- 底盘 -->
  <xacro:property name="base_radius"  value="0.110"/>
  <xacro:property name="base_height"  value="0.070"/>
  <xacro:property name="base_mass"    value="1.5"/>

  <!-- 驱动轮 -->
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_width"  value="0.018"/>
  <xacro:property name="wheel_mass"   value="0.2"/>
  <xacro:property name="track_width"  value="0.160"/>

  <!-- 万向轮 -->
  <xacro:property name="caster_radius" value="0.015"/>
  <xacro:property name="caster_x"      value="0.080"/>

  <!-- ════════════════════════════
       惯性矩辅助宏
       ——避免每次手算，直接调用
  ════════════════════════════════ -->
  <!-- 实心圆柱（轴沿 Z）：ixx=iyy=m*(3r²+h²)/12, izz=m*r²/2 -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0.0" ixz="0.0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0.0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- 实心球：ixx=iyy=izz=2*m*r²/5 -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${2*m*r*r/5}" ixy="0.0" ixz="0.0"
               iyy="${2*m*r*r/5}" iyz="0.0"
               izz="${2*m*r*r/5}"/>
    </inertial>
  </xacro:macro>

  <!-- 均匀长方体：ixx=m*(y²+z²)/12, iyy=m*(x²+z²)/12, izz=m*(x²+y²)/12 -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0.0" ixz="0.0"
               iyy="${m*(x*x+z*z)/12}" iyz="0.0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- ════════════════════════════
       轮子宏（核心：消除左右轮重复）
  ════════════════════════════════ -->
  <xacro:macro name="wheel" params="name y_offset">
    <link name="${name}_wheel_link">
      <visual>
        <!-- rpy="${pi/2} 0 0" 将圆柱从竖直转为水平 -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <!-- 调用惯性矩辅助宏（水平轴圆柱，x/z 轴为长轴） -->
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="0 ${y_offset} ${-base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

</robot>
