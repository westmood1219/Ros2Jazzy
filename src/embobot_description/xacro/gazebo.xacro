<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ①  材质颜色（Gazebo 有自己的材质系统，不认 URDF 的 material）-->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- ②  万向轮摩擦力（设为极小，让它可以自由滑动）-->
  <gazebo reference="caster_link">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="rear_caster_link">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ③  驱动轮摩擦力（较大，保证抓地力）-->
  <gazebo reference="left_wheel_link">
    <mu1>10.0</mu1>
    <mu2>5.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <mu1>10.0</mu1>
    <mu2>5.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- ④  激光雷达传感器插件（Gazebo Harmonic 语法）-->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>1</always_on>
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <gz_frame_id>lidar_link</gz_frame_id>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>${-pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.120</min>
          <max>10.0</max>
          <resolution>0.015</resolution>
        </range>
        <!-- 高斯噪声：模拟真实激光雷达的测量误差 -->
        <!-- mean=0 无系统偏差，stddev=0.01 约 1cm 标准差 -->
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <material>Gazebo/Blue</material>
    <sensor name="rgbd_camera_sensor" type="rgbd_camera">

      <topic>/camera</topic>
      <update_rate>15</update_rate>

      <!--
        gz_frame_id 用 camera_optical_frame（不是 camera_link！）
        原因：图像坐标系约定 Z 向前，需要经过旋转变换的光学帧
        这样 RViz2 中 Image 显示才方向正确
      -->
      <gz_frame_id>camera_optical_frame</gz_frame_id>

      <camera name="rgbd_camera">
        <horizontal_fov>1.3962634</horizontal_fov>  <!-- 80° 视角 -->

        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>  <!-- 24位 RGB -->
        </image>

        <clip>
          <near>0.05</near>   <!-- 近裁剪面 5cm -->
          <far>15.0</far>     <!-- 远裁剪面 15m -->
        </clip>

        <!-- 镜头畸变（0=无畸变，模拟理想相机） -->
        <distortion>
          <k1>0.0</k1>
          <k2>0.0</k2>
          <k3>0.0</k3>
          <p1>0.0</p1>
          <p2>0.0</p2>
          <center>0.5 0.5</center>
        </distortion>

        <!-- 深度图参数 -->
        <depth_camera>
          <output>depths</output>   <!-- 发布深度图 -->
        </depth_camera>

        <!-- 图像噪声（模拟传感器噪点） -->
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>

      </camera>

      <!-- 同时发布 camera_info（内参） -->
      <camera_info_topic>/camera/camera_info</camera_info_topic>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ⑤ Gazebo 原生差速驱动插件：直接订阅 Gazebo /model/embobot/cmd_vel -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.160</wheel_separation>
      <wheel_radius>0.033</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/model/embobot/cmd_vel</topic>
      <odom_topic>/model/embobot/odometry</odom_topic>
      <tf_topic>/model/embobot/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_velocity>0.5</max_linear_velocity>
      <min_linear_velocity>-0.5</min_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <min_angular_velocity>-2.0</min_angular_velocity>
    </plugin>

    <!-- ⑥ 发布 Gazebo 里的轮关节状态，供 ROS robot_state_publisher 生成轮子 TF -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
